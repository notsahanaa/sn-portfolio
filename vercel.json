{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "rewrites": [
    { "source": "/api/admin/projects/:path*", "destination": "/api/admin/projects/[...params]" },
    { "source": "/api/admin/writes/:path*", "destination": "/api/admin/writes/[...params]" },
    { "source": "/api/projects/:slug+", "destination": "/api/projects/[...slug]" },
    { "source": "/api/writes/:slug+", "destination": "/api/writes/[...slug]" },
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
